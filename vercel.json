{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "sw-tracker.js", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/sw-tracker.js", "dest": "/sw-tracker.js", "headers": { "Service-Worker-Allowed": "/" } },
    { "src": "/share/(.*)", "dest": "/share.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" }
  ],
  "crons": [
    {
      "path": "/api/check-offline",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/check-battery",
      "schedule": "0 8 * * *"
    }
  ]
}
